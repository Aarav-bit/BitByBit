generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYER
  FREELANCER
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique
  email            String    @unique
  name             String?
  role             Role?
  pfiScore         Int       @default(50)
  virtualBalance   Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  projectsCreated  Project[] @relation("EmployerProjects")
  projectsAssigned Project[] @relation("FreelancerProjects")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("ACTIVE")
  totalEscrow Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employerId  String
  employer    User     @relation("EmployerProjects", fields: [employerId], references: [id])
  
  freelancerId String?
  freelancer   User?    @relation("FreelancerProjects", fields: [freelancerId], references: [id])

  milestones  Milestone[]
}

model Milestone {
  id               String          @id @default(cuid())
  projectId        String
  project          Project         @relation(fields: [projectId], references: [id])
  title            String
  description      String
  amount           Float
  dueDate          DateTime?
  status           MilestoneStatus @default(PENDING)
  definitionOfDone String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  submissions      Submission[]
}

model Submission {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])
  content     String
  aqaResult   String?   // PASS, FAIL, PARTIAL
  aqaFeedback String?
  createdAt   DateTime  @default(now())
}
